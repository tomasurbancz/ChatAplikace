<UserControl x:Class="ChatAplikace.WPF.ChatView.ChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ChatAplikace.WPF.ChatView"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="LightGreen">
    
    <!-- Rozdělení: levý panel + chat -->
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="240"/>   <!-- LeftBar -->
        <ColumnDefinition Width="*"/>     <!-- ChatBar -->
    </Grid.ColumnDefinitions>

    <!-- LEFT BAR -->
    <Grid Grid.Column="0">
        <ScrollViewer VerticalScrollBarVisibility="Hidden">
            <ItemsControl ItemsSource="{Binding Chats}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding Name}"
                                Command="{Binding OpenCommand}"
                                Height="50"
                                Background="Green"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>

    <!-- CHAT BAR -->
    <Grid Grid.Column="1">
        
        <!-- Řádky: header + messages + input -->
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>   <!-- header -->
            <RowDefinition Height="*"/>    <!-- messages -->
            <RowDefinition Height="Auto"/> <!-- input -->
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0">
            <TextBlock Text="{Binding ChatUsername}"
                       Foreground="White"
                       FontSize="20"
                       VerticalAlignment="Center"
                       Margin="10"/>
        </Grid>

        <!-- MESSAGES -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
            <ItemsControl ItemsSource="{Binding Messages}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="5"
                                    HorizontalAlignment="{Binding Alignment}">

                            <Border CornerRadius="10"
                                    Padding="8"
                                    MaxWidth="300"
                                    Background="{Binding BackgroundColor}">
        
                                <StackPanel>
                                    <TextBlock Text="{Binding Message}"
                                               TextWrapping="Wrap"/>

                                    <TextBlock Text="{Binding Time}"
                                               FontSize="10"
                                               HorizontalAlignment="Right"
                                               Opacity="0.6"
                                               Margin="0,5,0,0"/>
                                </StackPanel>

                            </Border>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- INPUT (bonus) -->
        <Grid Grid.Row="2" Margin="5">
            <TextBox Height="40" Background="DarkGreen"/>
        </Grid>

    </Grid>
</Grid>
</UserControl>
